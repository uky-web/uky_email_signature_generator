<div id="result-html">
  <head>
    <style>
      body {font-size: 14px; line-height: 18px;}
      table {margin:0;padding:0;}
      tr {margin:0;padding:0;}
      .headshot {border-radius: 100%; max-width:100%; max-height: 100%;}
      .font {font-family:georgia,times,serif;}
      .inner-td{margin:0;padding:0;white-space:nowrap;}
      .color-tr{color:#b0a49b;}
      .logo-td1 {width:100px;margin:0;padding-right:10px; vertical-align: top;}
      .logo-td2{width:5px;}
      .right-top-td{margin:0;padding:0 20px; line-height: 1.3em; border-left:1px solid #0033a0;}
      .right-table{border:none;text-decoration:none;font-family:georgia,times,serif;font-size:14px;color:#0033a0;border-collapse:collapse;-webkit-text-size-adjust:none;}
      .name-span{font-size:1.6em;color:#0033a0;}
      .cred-span{font-size:1.5em;color:#0033a0;}
      .position-span{color:#0033a0;}
      .company-span{color:#0033a0; font-weight: 600;}
      .phone-letter{color:#0033a0;}
      .no-dec{border:none;text-decoration:none;}
      .phone-number{border:none;color:#0033a0;text-decoration:none;}
      .web-link{color:#0033a0;text-decoration:none;}
    </style>
  </head>
  <body>
  <div>
    -- <br />
    {% if name is not null and name is not empty %}
      <span class="name-span" style="font-family: georgia,times,serif; margin: 0; padding: 0; white-space: nowrap; color: #0033a0; font-size: 1.6em">
        {{ name }}{{ (creds is not null and creds is not empty) ? ', ' ~ creds : '' }}
      </span><br />
    {% endif %}
    {% if title is not null and title is not empty %}
      <span class="position-span" style="font-family: georgia,times,serif; margin: 0; padding: 0; white-space: nowrap; color: #000000; font-weight: bold;">
        {{ title }}
      </span><br />
    {% endif %}
    {% if university is not null and university is not empty %}
      <span class="university-span" style="font-family: georgia,times,serif; margin: 0; padding: 0; white-space: nowrap; color: #000000">
        {{ university }}
      </span><br />
    {% endif %}
    {% if department is not null and department is not empty %}
      <span class="department-span" style="font-family: georgia,times,serif; margin: 0; padding: 0; white-space: nowrap; color: #000000">
        {{ department }}
      </span><br />
    {% endif %}
    {% if sub_unit is not null and sub_unit is not empty %}
      <span class="unit-span" style="font-family: georgia,times,serif; margin: 0; padding: 0; white-space: nowrap; color: #000000">
        {{ sub_unit }}
      </span><br />
    {% endif %}
    {% if address is not null and address is not empty %}
      <span class="address-span" style="font-family: georgia,times,serif; margin: 0; padding: 0; white-space: nowrap; color: #000000">
        {{ address }}
      </span><br />
    {% endif %}
    {% if city is not null and city is not empty %}
      <span class="city-span" style="font-family: georgia,times,serif; margin: 0; padding: 0; white-space: nowrap; color: #000000">
        {{ city }}
      </span><br />
    {% endif %}
    {% if phone is not null and phone is not empty %}
      <a href="tel:{{ phone }}" target="_blank" class="no-dec" style="border: none; text-decoration: none">
        <span class="phone-span" style="font-family: georgia,times,serif; margin: 0; padding: 0; white-space: nowrap; border: none; color: #0033a0; text-decoration: none">
          {{ phone | format_phone }}
        </span>
      </a><br />
    {% endif %}
    {% if email is not null and email is not empty %}
      <a href="mailto:{{ email }}" target="_blank" class="no-dec web-link">
        <span class="email-span" style="font-family: georgia,times,serif; margin: 0; padding: 0; white-space: nowrap; border: none; color: #0033a0; text-decoration: none">
          {{ email }}
        </span>
      </a><br />
    {% endif %}
    <a href="https://uky.edu/" target="_blank">
      <img id="bottom-logo" width="250" height="98" style="width:250px; height: 98px;" alt="University of Kentucky logo"
           src="data:image/png;base64," />
    </a>
  </div>
  </body>
</div>
{% set lines = [] %}
{% set lines = lines|merge([name ~ (creds is not null and creds is not empty ? ', ' ~ creds : '')]) %}
{% if (title is not null and title is not empty) or (university is not null and university is not empty) %}
  {% set lines = lines|merge([title ~ (title is not null and title is not empty ? ', ' : '') ~ university]) %}
{% endif %}
{% if (department is not null and department is not empty) or (sub_unit is not null and sub_unit is not empty) %}
  {% set lines = lines|merge([department ~ (department is not null and department is not empty and sub_unit is not null and sub_unit is not empty ? ' - ' : '') ~ sub_unit]) %}
{% endif %}
{% if address is not null and address is not empty %}
  {% set lines = lines|merge(['', address]) %}
  {% set lines = lines|merge([city, '']) %}
{% endif %}
{% if phone is not null and phone is not empty %}
  {% set lines = lines|merge([phone | format_phone]) %}
{% endif %}
{% if email is not null and email is not empty %}
  {% set lines = lines|merge([email]) %}
{% endif %}
<div id="result-text">
-- 
{{ lines|join("\n") }}
</div>
